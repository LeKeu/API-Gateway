{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": { // qual requets casa com essa regra?
      "Route-Service-A": {
        "ClusterId": "cluster-service-a",
        "AuthorizationPolicy": "reader-policy",
        "Match": {
          "Path": "/api/produtos/{**catch-all}"
        }
      },
      "Route-Service-B": {
        "ClusterId": "cluster-service-b",
        "AuthorizationPolicy": "admin-policy",
        "Match": {
          "Path": "/api/pedidos/{**catch-all}" // catchall é um parametrso que pega tudo que vem depois
        }
      }
    },
    "Clusters": { // para onde esse request vai?
      "cluster-service-a": { // 1 cluster pode ter múltiplos destinos. aí que entraria o load balancer
        "Destinations": {
          "destination1": {
            "Address": "http://wiremock:8080"
          }
        }
      },
      "cluster-service-b": {
        "Destinations": {
          "destination1": {
            "Address": "http://wiremock:8080"
          }
        }
      }
    }
  },
  "Jwt": {
    "Authority": "http://keycloak:8080/realms/api-gateway", //usando keycloak e não localhost pq vai tá rodando dentro de docker, ent se comunica pelo nome do serviço
    "MetadataAddress": "http://keycloak:8080/realms/api-gateway/.well-known/openid-configuration",
    "ValidIssuer": "http://localhost:8080/realms/api-gateway",
    "Audience": "account",
    "RequireHttpsMetadata": false
  },
  "ConnectionStrings": {
    "Redis": "redis:6379"
  },
  "RateLimit": {
    "RequestsPerWindow": 10,
    "WindowSeconds": 60
  },
  "Cache": {
    "Routes": {
      "/api/produtos": { "TtlSeconds": 60 }
    }
  }
}
